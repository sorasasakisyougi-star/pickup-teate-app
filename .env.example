# LINE WORKS Bot (Phase 2b+) — fill at runtime, never commit real values
LW_BOT_ID=
LW_BOT_SECRET=
LW_API_ID=
LW_CLIENT_ID=
LW_CLIENT_SECRET=
LW_SERVICE_ACCOUNT=
LW_PRIVATE_KEY_PEM=

# Phase 2d-1: set to 1 to enable Bot text replies after process-inbox.
# Off by default. Requires all LW_* credentials above to be populated.
LW_BOT_REPLY_ENABLED=

# SQLite inbox path (defaults to ./.data/lw_inbox.db)
# LW_INBOX_DB_PATH=/var/pickup/lw_inbox.db

# Existing Power Automate relay (DO NOT CHANGE for V1)
# POWER_AUTOMATE_WEBHOOK_URL=
